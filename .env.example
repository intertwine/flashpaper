# FlashPaper Environment Configuration
# Copy this file to .env and fill in your values

# REQUIRED: Get your key from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Model - change when Gemini 3.5 Flash is the exact name released
GEMINI_MODEL=gemini-2.5-flash

# Demo mode: set to "true" to disable all real API calls and only serve seeded examples
DEMO_MODE=false

# Limits
MAX_PDF_MB=25

# Optional future: database URL, redis, etc.
# DATABASE_URL=sqlite:///./flashpaper.db
